# Caddy reverse proxy + SPA host for futsal-turniri.com.
#
# Runs inside the `edge` container (see frontend/Dockerfile). Talks to the
# `backend` service over the internal Docker network. Auto-fetches and
# renews TLS certs from Let's Encrypt on first start.
#
# Routing logic, top to bottom:
#   1. /api/*                       → backend (JSON API)
#   2. English aliases (English →   → 301 to Croatian canonical
#      Croatian)                       /tournaments → /turniri,
#                                      /profile → /profil, etc.
#   3. /                      +bot  → /api/preview/home              (SEO)
#   4. /turniri               +bot  → /api/preview/tournaments-list  (SEO)
#   5. /turniri/<slug>        +bot  → /api/preview/tournaments/<slug>(SEO)
#   6. /profil/<slug>         +bot  → /api/preview/profiles/<slug>   (SEO)
#   7. anything else                → SPA (file_server with index.html fallback)
#
# Routes 3-6 implement what Google's docs call "dynamic rendering":
# we serve crawlers an HTML page that already contains the content
# they need to index, while real users keep getting the SPA. The
# rewrite is internal (not a redirect), so the crawler indexes the
# content under its original URL (e.g. /turniri/abc), not under
# the preview URL.
{
	# Email Let's Encrypt uses for expiry warnings. Update if you switch.
	email mihael.rodek1@gmail.com

	# `rate_limit` is provided by the caddy-ratelimit module (baked into the
	# custom Caddy binary - see frontend/Dockerfile). It's a non-standard
	# directive, so it must be ordered explicitly: run it BEFORE reverse_proxy
	# so a throttled request is rejected (429) before it ever hits the backend.
	order rate_limit before reverse_proxy
}

futsal-turniri.com, www.futsal-turniri.com {
	encode zstd gzip

	# ─── 0. Maintenance mode ──────────────────────────────────────────
	# When the flag file /maintenance/ENABLED exists, short-circuit EVERY
	# request with a friendly "Nadogradnja u tijeku" page and HTTP 503 +
	# Retry-After (Google treats 503 as temporary and does NOT de-index).
	#
	# The flag lives on a host bind-mount (see docker-compose.prod.yaml),
	# so the deploy script toggles it with a plain `touch` / `rm` - no image
	# rebuild, no Caddy reload (the matcher stat()s the file per request) -
	# and it survives an edge-container restart mid-deploy.
	#
	# This handle is listed first, so it wins over the API / bot / SPA
	# handlers below whenever the flag is present. The maintenance page is
	# fully self-contained (inline CSS + SVG), so it needs no other assets
	# even though those would also return the 503 page during maintenance.
	@maintenance {
		file {
			root /maintenance
			try_files /ENABLED
		}
	}
	handle @maintenance {
		root * /srv
		rewrite * /maintenance.html
		header Cache-Control "no-store"
		header Retry-After "120"
		file_server {
			status 503
		}
	}

	# ─── 0. Block Quarkus non-application endpoints from the public ─────
	# /api/q/* is the SmallRye health / OpenAPI / metrics namespace. It must
	# NOT be reachable from the internet (it leaks datasource up/down state and
	# the internal stack). The docker-compose healthcheck hits the container
	# directly on the internal network, so nothing legitimate needs this path
	# through Caddy. Placed BEFORE the /api/* handler so it wins the match.
	handle /api/q/* {
		respond 404
	}

	# ─── 1a. Tight throttle on the expensive anonymous image renderers ─
	# share-image.png / qr.png / og/* each render a PNG per request (CPU +
	# multi-MB alloc). Social crawlers fetch them once per share; no legit
	# user hammers them. A tight per-IP cap blunts the CPU-amplification
	# vector. (The backend render cache is the primary defence; this is
	# belt-and-suspenders.) {remote_host} is the real client IP - Caddy is
	# the TLS edge with no CDN in front; add trusted_proxies + XFF if that
	# ever changes.
	@render path /api/og/* */share-image.png */qr.png
	handle @render {
		rate_limit {
			zone renders {
				key    {remote_host}
				events 120
				window 1m
			}
		}
		reverse_proxy backend:8085
	}

	# ─── 1. API - pass through to backend ─────────────────────────────
	# lb_try_duration makes Caddy keep retrying the backend for a few
	# seconds when it's briefly unreachable (cold start right after a
	# deploy, or a container restart) instead of immediately returning 502
	# to the SPA. Smooths the "first load after deploy fails" window.
	#
	# Generous per-IP request cap so a single host can't flood the API and
	# exhaust the DB pool / CPU. Set high (~50 req/s) so a venue crowd behind
	# ONE NAT IP never hits it, but far below what a flooding host does.
	handle /api/* {
		rate_limit {
			zone api {
				key    {remote_host}
				events 3000
				window 1m
			}
		}
		reverse_proxy backend:8085 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}
	# WebSocket - realtime live channel: instant live score/event push
	# for /uzivo + the fullscreen TV display. Caddy auto-detects the
	# Upgrade header and proxies the socket to the backend.
	#
	# NOTE: quarkus-websockets-next registers its endpoints UNDER
	# quarkus.http.root-path (/api), so the backend actually serves the
	# socket at /api/ws/live - the bare /ws/live returned 404 and every
	# client silently fell back to polling. Keep the public URL /ws/live
	# (clients + SW already use it) and rewrite here.
	handle /ws/* {
		rewrite * /api{path}
		reverse_proxy backend:8085
	}

	# Bare /sitemap.xml → the backend's dynamic sitemap. robots.txt already
	# points crawlers at /api/sitemap.xml, but the bare root path is the
	# convention Search Console users type in, so serve it there too.
	handle /sitemap.xml {
		rewrite * /api/sitemap.xml
		reverse_proxy backend:8085
	}

	# ─── 2. English → Croatian 301 redirects ──────────────────────────
	# The site moved off English URL slugs in favour of Croatian ones,
	# for two reasons:
	#   - SEO: a HR-language site should match the keyword strings HR
	#     users actually search for (a slug like /turniri/{event} is a
	#     better hit for "futsal turniri zagreb" than /tournaments/{event}).
	#   - UX: the rest of the UI is in HR, mixing English path segments
	#     into the address bar was a small but visible inconsistency.
	#
	# 301 (permanent) so Google consolidates ranking signal under the
	# Croatian URL. Anything that was already shared on WhatsApp/Slack
	# using the English URL keeps working - one redirect hop, then the
	# bot or browser lands on the canonical path.
	#
	# Specific paths come before regex catch-alls, because Caddy uses
	# most-specific-match-wins ordering and putting them in this order
	# also makes the intent obvious at a glance.

	# Specific paths first (so /tournaments/new isn't caught by the
	# regex below, and so the exact /tournaments redirect wins over the
	# /tournaments/{anything} pattern).
	redir /tournaments /turniri permanent
	redir /tournaments/new /turniri/novi permanent
	redir /profile /profil permanent
	redir /calendar /kalendar permanent
	redir /map /karta permanent
	redir /find-team /pronadi-ekipu permanent
	redir /login /prijava permanent
	redir /register /registracija permanent

	# Slug-bearing redirects use captured path groups so the segment
	# after the route name is preserved. {re.<name>.1} is Caddy's
	# placeholder for the first regex capture.
	@old_tournament_slug {
		path_regexp old_t ^/tournaments/(.+)$
		# Guard against the more-specific /tournaments/new which is
		# already handled by an exact redir above.
		not path /tournaments/new
	}
	redir @old_tournament_slug /turniri/{re.old_t.1} permanent

	@old_profile_slug path_regexp old_p ^/profile/(.+)$
	redir @old_profile_slug /profil/{re.old_p.1} permanent

	@old_claim_team path_regexp old_cp ^/claim-team/(.+)$
	redir @old_claim_team /preuzmi-ekipu/{re.old_cp.1} permanent

	@old_claim_name path_regexp old_cn ^/claim-name/(.+)$
	redir @old_claim_name /preuzmi-ime/{re.old_cn.1} permanent

	# Crawler UA matchers - shared regex for the bots we want to serve
	# pre-rendered HTML to. Two buckets:
	#   - INDEXING bots (googlebot, bingbot, duckduckbot, applebot,
	#     yandexbot) - we want these to read our preview HTML so the
	#     SPA's empty index.html doesn't get indexed instead. These
	#     are case-insensitive and matched against User-Agent.
	#   - LINK-PREVIEW bots (facebookexternalhit, whatsapp, telegrambot,
	#     slackbot, twitterbot, linkedinbot, discordbot, pinterest,
	#     skypeuripreview) - these read <head> only for OG previews.
	# We hit both with the same rewrite because the preview controllers
	# serve content that's correct for either purpose: rich <head> for
	# link-preview, full <body> for indexing.
	#
	# All matchers below target the Croatian canonical paths. English
	# aliases have already been redirected upstream, so by the time a
	# crawler reaches these matchers it's always on a /turniri/...
	# or /profil/... URL.

	# ─── 3. Homepage SSR preview for crawlers ─────────────────────────
	# `/` is where most ranking searches like "futsal turniri" land. The
	# SPA's index.html has no content for Googlebot to index until JS
	# finishes rendering, which on a small/new domain can take days. This
	# rewrite serves the homepage with real Croatian text and a list of
	# upcoming tournaments to bots immediately.
	@home_for_bot {
		path /
		header_regexp User-Agent (?i)(facebookexternalhit|whatsapp|telegrambot|slackbot|twitterbot|linkedinbot|discordbot|skypeuripreview|pinterest|applebot|googlebot|bingbot|duckduckbot|yandexbot)
	}
	handle @home_for_bot {
		rewrite * /api/preview/home
		reverse_proxy backend:8085
	}

	# ─── 4. Tournament list SSR preview for crawlers ──────────────────
	# `/turniri` is the second-highest-traffic SEO page. Same
	# pre-rendering rationale as the homepage.
	@tournaments_list_for_bot {
		path /turniri
		header_regexp User-Agent (?i)(facebookexternalhit|whatsapp|telegrambot|slackbot|twitterbot|linkedinbot|discordbot|skypeuripreview|pinterest|applebot|googlebot|bingbot|duckduckbot|yandexbot)
	}
	handle @tournaments_list_for_bot {
		rewrite * /api/preview/tournaments-list
		reverse_proxy backend:8085
	}

	# ─── 5. Tournament SSR preview for crawlers ────────────────────────
	# Match must include BOTH a tournament-detail path AND a known
	# crawler User-Agent. Real users fall through to the SPA below.
	# The path segment can be either a UUID (legacy URLs) or the new
	# human-readable slug (e.g. "1-futsal-open-22-04-2026"). The backend
	# /api/preview/tournaments/{idOrSlug} endpoint accepts both.
	#
	# Caddy uses Go's RE2 regex engine, which does NOT support negative
	# lookaheads - that's why `/turniri/novi` is excluded with a
	# separate `not path` matcher rather than `(?!novi$)` inline.
	@tournament_for_bot {
		path_regexp tournament_slug ^/turniri/([a-z0-9][a-z0-9-]*)$
		not path /turniri/novi
		header_regexp User-Agent (?i)(facebookexternalhit|whatsapp|telegrambot|slackbot|twitterbot|linkedinbot|discordbot|skypeuripreview|pinterest|applebot|googlebot|bingbot|duckduckbot|yandexbot)
	}
	handle @tournament_for_bot {
		# Backend preview API still lives under /api/preview/tournaments/
		# (English) - that's an internal contract URL, not user-facing,
		# so we don't translate it. Just remap path here.
		rewrite * /api/preview/tournaments/{re.tournament_slug.1}
		reverse_proxy backend:8085
	}

	# ─── 6. Profile SSR preview for crawlers ──────────────────────────
	# SPA route is /profil/<slug> (singular); backend endpoint is
	# /api/preview/profiles/<slug> (plural English) - see comment above
	# about backend API paths staying English.
	@profile_for_bot {
		path_regexp profile ^/profil/([a-z0-9][a-z0-9-]*)$
		header_regexp User-Agent (?i)(facebookexternalhit|whatsapp|telegrambot|slackbot|twitterbot|linkedinbot|discordbot|skypeuripreview|pinterest|applebot|googlebot|bingbot|duckduckbot|yandexbot)
	}
	handle @profile_for_bot {
		rewrite * /api/preview/profiles/{re.profile.1}
		reverse_proxy backend:8085
	}

	# ─── 7. Embed widgets (iframe-able) ────────────────────────────────
	# Public scoreboard widgets meant to be iframed into 3rd-party sites
	# (club pages, sponsor portals). The global X-Frame-Options: DENY
	# below blocks framing entirely; here we override with a CSP that
	# allows framing from any origin, and strip the legacy header so it
	# doesn't fight CSP. Path is matched before SPA fallback so the
	# header override actually applies.
	handle /embed/* {
		header {
			-X-Frame-Options
			Content-Security-Policy "frame-ancestors *"
		}
		root * /srv
		file_server
		try_files {path} /index.html
	}

	# ─── 8. SPA fallback ───────────────────────────────────────────────
	# Static files from /srv (baked in by frontend/Dockerfile). Any
	# unknown path falls back to /index.html so React Router can take over.
	handle {
		root * /srv
		file_server
		try_files {path} /index.html
	}

	# ─── Cache policy for static assets ────────────────────────────────
	# Vite emits content-hashed files under /assets/ (e.g. index-AbC123.js).
	# The hash changes whenever the content does, so these are safe to cache
	# forever - the browser never has to re-validate them.
	@immutable path /assets/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Non-hashed static images (logos, PWA icons, favicons). Not immutable -
	# they keep their filenames across redesigns - but they change rarely, so
	# a week of caching kills the repeated re-fetches Lighthouse flags
	# (ttl=0 on /logo/*.svg, /icon-192.png). A redesign that must show up
	# instantly should rename the file instead of relying on cache expiry.
	@staticimg path *.png *.svg *.ico *.webp *.jpg *.jpeg
	header @staticimg Cache-Control "public, max-age=604800"

	# The HTML shell, service worker and manifest must NOT be cached, or a
	# deploy wouldn't take effect until the old copies expire. `no-cache`
	# means "revalidate every time" (cheap 304 when unchanged), so a fresh
	# index.html always points at the latest hashed asset bundle.
	@nostore path / /index.html /sw.js /manifest.webmanifest
	header @nostore Cache-Control "no-cache"

	# ─── Security headers (defense-in-depth) ───────────────────────────
	# The backend has its own SecurityHeadersFilter; setting them here too
	# covers static-asset responses where the backend filter never runs.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=(), payment=(), interest-cohort=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# Don't advertise the server name.
		-Server
	}

	# ─── Content-Security-Policy (ENFORCING) ───────────────────────────
	# Scoped to everything EXCEPT /embed/* - embed widgets must stay frameable
	# (they set their own `frame-ancestors *` CSP above; a global
	# frame-ancestors 'none' here would intersect to 'none' and break embeds).
	#
	# Source list reflects exactly what the app loads:
	#   - script/style 'unsafe-inline'  → the inline theme (no-flash) script in
	#     index.html + Chakra's injected styles.
	#   - fonts.googleapis.com / fonts.gstatic.com → the Google Fonts stylesheet
	#     (@import in ds-styles.css) + the font files.
	#   - googletagmanager.com → the Google Analytics 4 gtag.js loader
	#     (index.html); its collect beacons go over connect-src https:.
	#   - img 'self' data: blob: https:  → CARTO map tiles, MinIO images, avatars.
	#   - connect 'self' https: wss:     → the API + WebSocket, Firebase Auth,
	#     Nominatim geocoding (all browser-side over https).
	#   - frame-src firebaseapp.com / google → Firebase Auth's hidden iframe +
	#     Google sign-in; youtube / veo → the live-stream player's embeds
	#     (organizer's court camera). Streaming another provider? Add its
	#     domain here or the iframe stays blank in production.
	#   - media-src 'self' blob: https:  → the live-stream <video>: hls.js
	#     plays through a blob: MediaSource; Safari-native HLS + direct MP4
	#     load straight from the camera/CDN host over https.
	# object-src / base-uri / form-action / frame-ancestors are locked down.
	@notembed not path /embed/*
	header @notembed Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.googleapis.com https://*.gstatic.com https://apis.google.com https://*.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https: wss:; frame-src 'self' https://*.firebaseapp.com https://*.google.com https://accounts.google.com https://www.youtube-nocookie.com https://www.youtube.com https://*.veo.co; worker-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

	# Smaller-than-default access log to stderr; tweak when you wire up
	# log aggregation.
	log {
		output stderr
		format console
		level INFO
	}
}
