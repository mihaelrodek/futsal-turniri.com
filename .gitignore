# ──────────────────────────────────────────────────────────
# Secrets & local config - NEVER commit these
# ──────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.prod
.env.staging
*.env
!.env.example
!.env.prod.example
# Firebase Admin SDK service-account key - full project access
scripts/service-account.json
scripts/node_modules/
# Seed-script Firebase ID token (short-lived, but still a credential)
scripts/seed-token.txt
scripts/seed_token.txt

# ──────────────────────────────────────────────────────────
# OS cruft
# ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────
# IDEs / editors
# .idea keeps its own nested .gitignore (JetBrains default)
# so shared code-style lives in VCS while workspace files don't.
# ──────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────
# Backend - Maven / Quarkus
# ──────────────────────────────────────────────────────────
backend/target/
backend/.quarkus/
backend/dependency-reduced-pom.xml
backend/build-metrics.json
backend/**/*.class
backend/HELP.md

# Spring-style MVN log, if anything ever writes one
*.log
log/

# ──────────────────────────────────────────────────────────
# Frontend - Node / Vite
# (frontend/.gitignore already covers these; mirrored here as a safety net)
# ──────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# ──────────────────────────────────────────────────────────
# Runtime artefacts
# RESTEasy Reactive writes temp uploads here (see application.properties)
# ──────────────────────────────────────────────────────────
uploads/
backend/uploads/

# Maintenance flag - toggled at deploy time by ops/deploy.sh, never committed
ops/maintenance/ENABLED

# ──────────────────────────────────────────────────────────
# design-sync (claude.ai/design) - generated + machine state.
# The durable inputs under .design-sync/ (config.json, NOTES.md,
# conventions.md, previews/, overrides/) ARE committed.
# ──────────────────────────────────────────────────────────
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
