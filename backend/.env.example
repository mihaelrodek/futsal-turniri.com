# Example backend env. Copy to .env (git-ignored) and fill in real values.
#
# SpectoStream live-overlay integration (consumed via application.properties:
# specto.base-url / specto.api-key / specto.enabled). Leave SPECTO_API_KEY blank
# to disable streaming entirely. Get a real key (sps_...) from the SpectoStream
# portal -> API keys.
SPECTO_BASE_URL=https://stream.safeflow.hr
SPECTO_API_KEY=futsaltest
SPECTO_ENABLED=true
