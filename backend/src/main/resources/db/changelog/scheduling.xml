<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!-- Phase E4: match scheduling. Match-format config on the tournament,
         a kickoff time on each match. Single court — matches are sequential. -->
    <changeSet id="2026-05-21-07-scheduling" author="mrodek">
        <addColumn tableName="tournaments">
            <column name="half_count" type="int" defaultValueNumeric="2"/>
            <column name="half_length_min" type="int"/>
            <column name="halftime_break_min" type="int"/>
            <column name="break_between_matches_min" type="int"/>
            <column name="buffer_min" type="int"/>
        </addColumn>
        <addColumn tableName="matches">
            <column name="kickoff_at" type="timestamptz"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
