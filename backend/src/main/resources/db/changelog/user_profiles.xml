<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Per-Firebase-user profile data we don't get from the token: contact
        phone, public slug + display name, optional avatar, theme preference.
        Keyed by the Firebase UID; one row per user. Full consolidated
        definition (pre-launch baseline). FK to resources (avatar), so ordered
        after resources.
    -->
    <changeSet id="2026-04-26-70-user-profiles" author="mrodek">
        <createTable tableName="user_profiles">
            <column name="user_uid" type="varchar(64)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="phone_country" type="varchar(8)"/>
            <column name="phone" type="varchar(50)"/>

            <!-- public profile -->
            <column name="display_name" type="varchar(200)"/>
            <column name="slug" type="varchar(200)"/>

            <!-- optional avatar (FK to resources) -->
            <column name="avatar_resource_id" type="bigint"/>

            <!-- theme preference; null = no preference (frontend default) -->
            <column name="color_mode" type="varchar(10)"/>

            <column name="updated_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="user_profiles"
                                 baseColumnNames="avatar_resource_id"
                                 referencedTableName="resources"
                                 referencedColumnNames="id"
                                 onDelete="SET NULL"
                                 constraintName="fk_user_profiles_avatar"/>

        <createIndex tableName="user_profiles" indexName="ux_user_profiles_slug" unique="true">
            <column name="slug"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
