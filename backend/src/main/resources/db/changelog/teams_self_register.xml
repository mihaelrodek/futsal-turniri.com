<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Self-registration: a logged-in user can submit their own team against
        any not-yet-started tournament. The row is created with
        pending_approval=true and submitted_by_uid=their Firebase UID; the
        organizer flips pending_approval=false to confirm. Organizer-added
        teams default to pending_approval=false (already approved).
    -->
    <changeSet id="2026-04-26-40-teams-self-register" author="mrodek">
        <addColumn tableName="teams">
            <column name="submitted_by_uid" type="varchar(64)"/>
            <column name="pending_approval" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <createIndex tableName="teams" indexName="idx_teams_submitted_by">
            <column name="submitted_by_uid"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
