<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        User email, mirrored from the Firebase ID token on /user/me/sync so the
        backend can send tournament-notification emails. Nullable — backfilled
        naturally the next time each user logs in and the SPA calls sync.
    -->
    <changeSet id="2026-07-06-user-profiles-email" author="mrodek">
        <addColumn tableName="user_profiles">
            <column name="email" type="varchar(320)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
