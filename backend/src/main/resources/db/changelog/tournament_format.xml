<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!-- Phase E1: futsal tournament format configuration.
         format            — GROUPS_KNOCKOUT | KNOCKOUT_ONLY
         group_count       — number of groups (GROUPS_KNOCKOUT only)
         advance_per_group — teams advancing from each group (GROUPS_KNOCKOUT only)
         bracket_fill      — BYES | WILDCARDS (GROUPS_KNOCKOUT only) -->
    <changeSet id="2026-05-21-01-tournament-format" author="mrodek">
        <addColumn tableName="tournaments">
            <column name="format" type="varchar(20)" defaultValue="GROUPS_KNOCKOUT">
                <constraints nullable="false"/>
            </column>
            <column name="group_count" type="int"/>
            <column name="advance_per_group" type="int"/>
            <column name="bracket_fill" type="varchar(20)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
