<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Co-editors of a tournament: registered users granted management rights
        on a single tournament WITHOUT transferring ownership. The creator
        (created_by_uid) stays the owner; each row here is an additional person
        who passes the same assertCanEdit gate (edit details, teams, schedule,
        run the Zapisnik, …). Assigned by an admin from the dashboard; a
        tournament can have many. Unique per (tournament, user).
    -->
    <changeSet id="2026-07-11-tournament-editors-seq" author="mrodek">
        <createSequence sequenceName="seq_tournament_editors_id" incrementBy="1" startValue="1"/>
    </changeSet>

    <changeSet id="2026-07-11-tournament-editors" author="mrodek">
        <createTable tableName="tournament_editors">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tournament_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="user_uid" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="NOW()"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="tournament_editors" baseColumnNames="tournament_id"
                                 referencedTableName="tournaments" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_tournament_editors_tournament"/>

        <addUniqueConstraint tableName="tournament_editors" columnNames="tournament_id, user_uid"
                             constraintName="uq_tournament_editor"/>

        <createIndex tableName="tournament_editors" indexName="idx_tournament_editors_tournament">
            <column name="tournament_id"/>
        </createIndex>
        <createIndex tableName="tournament_editors" indexName="idx_tournament_editors_user_uid">
            <column name="user_uid"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
