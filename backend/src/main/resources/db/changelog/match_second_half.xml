<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
      2nd-half kickoff timestamp on matches. second_half_started_at is the
      wall-clock instant the 2nd half started, set by POST .../second-half.
      Nullable — only populated once the organizer kicks off the 2nd half.
    -->

    <changeSet id="2026-05-23-31-matches-second-half" author="mrodek">
        <addColumn tableName="matches">
            <column name="second_half_started_at" type="timestamptz"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
