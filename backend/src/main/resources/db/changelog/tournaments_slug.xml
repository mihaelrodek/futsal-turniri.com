<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Human-readable URL slug for tournaments, e.g. "1st-futsal-open-22-04-2026".
        Built from name + start date, with collision handling done in Java.
        Nullable because existing rows are backfilled lazily by SlugBackfillService
        on application startup; once backfilled, all rows have a slug. The unique
        index allows nulls (one-time during backfill) but enforces uniqueness once
        the column is populated.

        Length 220 leaves headroom for the hyphenated date suffix and a small
        numeric disambiguator (e.g. "-2") when two tournaments would otherwise
        produce the same slug. Tournament name itself is capped at 200.
    -->
    <changeSet id="2026-05-10-11-tournaments-slug" author="mrodek">
        <addColumn tableName="tournaments">
            <column name="slug" type="varchar(220)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex tableName="tournaments" indexName="idx_tournaments_slug" unique="true">
            <column name="slug"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
