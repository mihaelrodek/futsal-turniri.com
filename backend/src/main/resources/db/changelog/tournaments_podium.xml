<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
      Podium (silver + bronze) at tournament end. We already store the
      gold position in tournaments.winner_name (set on FINISH). The two
      columns below let the organiser also record who finished 2nd and
      3rd, so the public profile / SPA can render the full medal stack
      instead of just the champion.

      Both columns are nullable — small tournaments (≤2 active teams at
      finish) may legitimately have no bronze, and the organiser can
      leave the entire podium blank if they don't care. Width matches
      Teams.name (varchar(200)) so any team name fits without truncation.
    -->

    <changeSet id="2026-05-14-tournaments-podium" author="mrodek">
        <addColumn tableName="tournaments">
            <column name="second_place_name" type="varchar(200)"/>
            <column name="third_place_name"  type="varchar(200)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
