<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Track who created each team-finding request. Only the original poster
        (or an admin) is allowed to mark it matched or delete it; everyone else
        can read.
    -->
    <changeSet id="2026-04-26-60-team-requests-creator" author="mrodek">
        <addColumn tableName="team_requests">
            <column name="created_by_uid" type="varchar(64)"/>
        </addColumn>
        <createIndex tableName="team_requests" indexName="idx_team_requests_created_by">
            <column name="created_by_uid"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
