<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Accumulated team fouls, tracked per half (futsal rule: from a team's
        5th accumulated foul in a half the opponent gets a 10 m direct free
        kick — "deveterac"; each subsequent foul is another one). Fouls don't
        record who committed them, only the per-team running count, and reset
        every half — hence separate first/second-half columns per team.
    -->
    <changeSet id="2026-06-24-match-fouls" author="mrodek">
        <addColumn tableName="matches">
            <column name="fouls1_first" type="int" defaultValueNumeric="0"/>
            <column name="fouls1_second" type="int" defaultValueNumeric="0"/>
            <column name="fouls2_first" type="int" defaultValueNumeric="0"/>
            <column name="fouls2_second" type="int" defaultValueNumeric="0"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
