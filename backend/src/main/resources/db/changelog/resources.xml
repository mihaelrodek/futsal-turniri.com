<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!-- Sequence -->
    <changeSet id="2025-11-01-10-resources-seq" author="mrodek">
        <createSequence sequenceName="seq_resources_id" incrementBy="1" startValue="1"/>
    </changeSet>

    <!-- Table -->
    <changeSet id="2025-11-01-11-resources" author="mrodek">
        <createTable tableName="resources">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="bucket_name" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="object_key" type="varchar(512)">
                <constraints nullable="false"/>
            </column>

            <column name="content_type" type="varchar(120)"/>
            <column name="size_bytes" type="bigint"/>
            <column name="etag" type="varchar(128)"/>
            <column name="public_url" type="text"/>
            <column name="metadata" type="jsonb"/>

            <column name="created_at" type="timestamptz" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="NOW()"/>
        </createTable>

        <addUniqueConstraint tableName="resources"
                             columnNames="bucket_name,object_key"
                             constraintName="uq_resources_bucket_object"/>
        <createIndex tableName="resources" indexName="idx_resources_bucket">
            <column name="bucket_name"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>