<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
      Individual awards set by the organiser when a tournament finishes:
      best goalkeeper, best player (MVP), best scorer. Free-text player
      names (uppercased like the roster) so they also work for legacy /
      imported tournaments where no Player row exists. The best-scorer
      award additionally feeds a tiebreaker on the all-time scorer list
      (a player who's been top scorer somewhere ranks above an equal-goal
      player who hasn't).

      All nullable — awards are optional and can be filled in any time
      after finish. Width matches Player.name / Teams.name (varchar(200)).
    -->

    <changeSet id="2026-06-21-tournament-awards" author="mrodek">
        <addColumn tableName="tournaments">
            <column name="best_goalkeeper_name" type="varchar(200)"/>
            <column name="best_player_name"     type="varchar(200)"/>
            <column name="best_scorer_name"     type="varchar(200)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
