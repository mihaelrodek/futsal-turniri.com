# Copy to `.env.local` and fill in real values (see `.gitignore`).
#
# Firebase web config - not secret per Firebase's docs (they identify the
# project, not authorize access). Real security comes from App Check +
# Auth domain restrictions in the Google Cloud console, plus server-side
# ID-token verification by the Quarkus backend. Still: lock this key down
# to your production domain(s) before launch.
VITE_FIREBASE_API_KEY=AIzaSyAlU3-tgNk4xxcPU0t4AHi5Se5XVXm1Gwg
VITE_FIREBASE_AUTH_DOMAIN=futsal-turniri.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=futsal-turniri
VITE_FIREBASE_APP_ID=1:830530778451:web:a54d74d388506f5fc95da6

# Optional: override the API base URL.
# Defaults to "/api" - fine in dev (Vite proxy) and in prod when nginx
# serves the SPA and proxies /api/* to the backend on the same origin.
# Only set this when the backend lives on a different origin than the SPA.
