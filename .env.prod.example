# ⚠ Copy these from the FUTSAL-TURNIRI Firebase project ONLY
# (Console → project "futsal-turniri" → Project settings → Your apps → Web app
#  → SDK setup and configuration). Do NOT paste another project's key - the
# apiKey is what tells the SDK which project to use, so a wrong key sends auth
# to the wrong project and Google logins fail with auth/unauthorized-domain.
VITE_FIREBASE_API_KEY=CHANGE_ME_FUTSAL_TURNIRI_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=futsal-turniri.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=futsal-turniri
VITE_FIREBASE_APP_ID=CHANGE_ME_FUTSAL_TURNIRI_APP_ID

