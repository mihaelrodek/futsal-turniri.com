# Copy to `.env.prod` on the server and fill in real values.
# `.env.prod` is gitignored — do NOT commit it.
#
# Usage:
#   docker compose -f docker-compose.prod.yaml --env-file .env.prod up -d --build
#
# Generate strong random passwords with:
#   openssl rand -base64 24

# ─────────────── Postgres ───────────────
POSTGRES_DB=futsal_turniri_prod
POSTGRES_USER=futsal
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING

# ─────────────── MinIO (private bucket; not exposed on host) ───────────────
MINIO_ROOT_USER=futsal-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING
MINIO_BUCKET=futsal-posters

# ─────────────── Firebase Auth ───────────────
# Backend only verifies tokens — no client secret needed.
FIREBASE_PROJECT_ID=futsal-turniri

# ─────────────── Public-facing URLs ───────────────
# CORS_ORIGINS — comma-separated list of origins the API trusts. SPA + API
# are served from the same origin via Caddy, so CORS preflights never fire
# in normal use, but this still gates direct curl/Postman traffic.
CORS_ORIGINS=https://nogometni-turniri.com,https://www.nogometni-turniri.com

# Used by the sitemap, OG previews, and the startup sanity check.
APP_PUBLIC_BASE_URL=https://nogometni-turniri.com

# ─────────────── Frontend (build-time, baked into the SPA bundle) ───────────────
# Same-origin routing through Caddy → /api goes to the backend.
VITE_API_URL=/api

# Firebase web config — public per Firebase's docs. Lock down the API key
# in Google Cloud Console → Credentials to your prod domain(s) before launch.
VITE_FIREBASE_API_KEY=AIzaSyAlU3-tgNk4xxcPU0t4AHi5Se5XVXm1Gwg
VITE_FIREBASE_AUTH_DOMAIN=futsal-turniri.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=futsal-turniri
VITE_FIREBASE_APP_ID=1:830530778451:web:a54d74d388506f5fc95da6
